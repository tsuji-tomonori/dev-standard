{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atomic durable requirements catalog",
  "type": "object",
  "required": ["schema_version", "catalog_revision", "product", "updated_at", "requirements"],
  "properties": {
    "schema_version": {"const": 1},
    "catalog_revision": {"type": "integer", "minimum": 0},
    "product": {"type": "string", "minLength": 1},
    "updated_at": {"type": "string", "format": "date"},
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "revision", "status", "type", "title", "subject", "action", "object", "rationale", "source_refs", "acceptance_criteria", "verification", "traces", "last_changed_by"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Z][A-Z0-9]+(?:-[A-Z0-9]+)+$"},
          "revision": {"type": "integer", "minimum": 1},
          "status": {"enum": ["active", "retired"]},
          "type": {"enum": ["functional", "quality", "constraint", "interface", "data", "operational"]},
          "scope": {"enum": ["product", "project"]},
          "category": {"enum": ["functional", "nonfunctional"]},
          "title": {"type": "string", "minLength": 1},
          "subject": {"type": "string", "minLength": 1},
          "action": {"type": "string", "pattern": "^[a-z][a-z0-9]*$"},
          "object": {"type": "string", "minLength": 1, "pattern": "^[^;\\r\\n]+$"},
          "rationale": {"type": "string", "minLength": 1},
          "source_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "given", "when", "then"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "given": {"type": "string", "minLength": 1},
                "when": {"type": "string", "minLength": 1},
                "then": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          },
          "verification": {
            "type": "object",
            "required": ["method", "evidence"],
            "properties": {
              "method": {"type": "string", "minLength": 1},
              "evidence": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          },
          "traces": {
            "type": "object",
            "required": ["design", "implementation", "tests", "standards"],
            "properties": {
              "design": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "implementation": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "tests": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "standards": {"type": "array", "items": {"type": "string", "minLength": 1}}
            },
            "additionalProperties": false
          },
          "last_changed_by": {"type": "string", "minLength": 1},
          "retirement_reason": {"type": "string"},
          "superseded_by": {"type": "string"}
        },
        "additionalProperties": false,
        "dependentRequired": {
          "scope": ["category"],
          "category": ["scope"]
        },
        "allOf": [{
          "if": {"properties": {"status": {"const": "retired"}}},
          "then": {"required": ["retirement_reason"], "properties": {"retirement_reason": {"minLength": 1}}}
        }]
      }
    }
  },
  "additionalProperties": false
}
